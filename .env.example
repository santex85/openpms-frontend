# Base URL of the OpenPMS FastAPI backend (no trailing slash).
# TZ-13 stack (Caddy reverse proxy): API is on port 80 → use e.g. http://127.0.0.1
# Direct uvicorn (no Caddy): often http://localhost:8000 — match docker-compose published port.
# If wrong or empty, the browser calls the Vite dev server and you get 404 / CORS errors.
VITE_API_BASE_URL=http://127.0.0.1

# After changing .env, restart `npm run dev` so Vite picks up values.
# Backend CORS_ORIGINS must include this app origin (e.g. http://localhost:5173).
# Quick check: npm run check:api  → GET …/health should show {"status":"ok"}.

# Local Docker OpenPMS: mint JWT and get a dev login link -> npm run mint:jwt

# Show GET/POST/PATCH route hints in the app (end users should leave this unset).
# VITE_SHOW_API_ROUTES=true

# Set to "true" only if backend has no PATCH /bookings/{id} and you want silent no-op (not recommended).
# VITE_MOCK_BOOKING_ASSIGN=

# Refresh sessions: when the backend issues an httpOnly refresh cookie for POST /auth/refresh,
# keep `withCredentials: true` on the API client (already the default). Align CORS with
# Access-Control-Allow-Credentials and a concrete origin (not *). Tenant/bootstrap may still
# use body or sessionStorage until the API supports cookie-only refresh.
