# Base URL of the OpenPMS FastAPI backend (no trailing slash).
# Example: http://localhost:8000
VITE_API_BASE_URL=

# After changing .env, restart `npm run dev` so Vite picks up values.
# Open the app from an origin allowed by API CORS_ORIGINS (e.g. http://localhost:5173).

# Local Docker OpenPMS: mint JWT and get a dev login link -> npm run mint:jwt

# Show GET/POST/PATCH route hints in the app (end users should leave this unset).
# VITE_SHOW_API_ROUTES=true

# Set to "true" only if backend has no PATCH /bookings/{id} and you want silent no-op (not recommended).
# VITE_MOCK_BOOKING_ASSIGN=
